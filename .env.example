# Copy to .env (cp .env.example .env) and edit. .env is gitignored.

# --- model -------------------------------------------------------------------

# MODELS_DIR: host folder holding your GGUF files (mounted read-only at /models).
MODELS_DIR=/home/hec/models/gguf

# LLM_MODEL: the GGUF file to serve, RELATIVE to MODELS_DIR. Required.
# Swap this line to test a different model, then `docker compose up -d`.
LLM_MODEL=laguna-s-2.1/laguna-s-2.1-Q4_K_M.gguf

# LLM_ALIAS: model name reported by the OpenAI API (/v1/models, response "model").
LLM_ALIAS=llm

# LLM_CHAT_TEMPLATE: jinja chat template file, RELATIVE to MODELS_DIR. Required.
# Keep each model's template next to its GGUF. Extract the embedded one with
# gguf-py if the file does not exist yet, or drop in a vendor-refreshed template
# when the embedded one is stale (gemma's 2026-07-15 fix, for example).
LLM_CHAT_TEMPLATE=laguna-s-2.1/chat_template.jinja

# --- server knobs ------------------------------------------------------------

# LLM_PORT: host port for the OpenAI-compatible API.
LLM_PORT=8080

# LLM_NGL: layers offloaded to the GPU. 99 = all (the point of using Vulkan).
LLM_NGL=99

# llama.cpp's --ctx-size is the TOTAL KV cache, not a per-request limit. With
# fixed non-unified slots, each request gets LLM_CTX_TOTAL / LLM_PARALLEL.
# Keep these three values consistent. Five 131k slots match noob's default
# context and reserve one parent slot beside four detached child slots.
LLM_CTX_PER_SLOT=131072
LLM_PARALLEL=5
LLM_CTX_TOTAL=655360

# Model-specific server flags (rope scaling, flash-attn, chat-template-kwargs,
# etc.) are not env knobs here: add them to the `command:` list in
# docker-compose.yml or a compose override file when a model needs them.

# --- GPU access (Strix Halo) -------------------------------------------------

# Group IDs so the container can reach /dev/dri. Find yours:
#   getent group render | cut -d: -f3   -> RENDER_GID
#   getent group video  | cut -d: -f3   -> VIDEO_GID
RENDER_GID=990
VIDEO_GID=44

# GTT (not VRAM) is forced in docker-compose.yml via GGML_VK_PREFER_HOST_MEMORY=1.
# It is a presence check in llama.cpp (any value enables it); to ever turn it off
# you remove that env line from the compose file, you cannot set it to 0.

# --- web search sidecar (optional, profile: tools) ---------------------------

# Enable with `docker compose --profile tools up -d`, or uncomment:
# COMPOSE_PROFILES=tools

# WEBSEARCH_PORT: host port for the websearch MCP server (endpoint /mcp).
WEBSEARCH_PORT=8000

# --- ROCmFP4 + MTP stack (separate file: docker-compose.rocmfp4.yml) ----------
# Only used by that file, not the base stack. It BUILDS the custom fork and needs
# /dev/kfd + ROCm; the base Vulkan stack above does not. Bring it up with:
#   docker compose -f docker-compose.rocmfp4.yml up -d --build

# ROCMFP4_MODEL: the ROCmFP4 GGUF to serve, RELATIVE to MODELS_DIR. Required by
# that file (fails fast at up/config if blank).
ROCMFP4_MODEL=Qwen3.6-35B-A3B-MTP-ROCmFP4/Qwen3.6-35B-A3B-MTP-ROCmFP4-STRIX-embF16-headQ6.gguf

# ROCMFP4_CHAT_TEMPLATE: jinja template shipped with the model, RELATIVE to MODELS_DIR.
ROCMFP4_CHAT_TEMPLATE=Qwen3.6-35B-A3B-MTP-ROCmFP4/chat_template.jinja

# ROCMFP4_ALIAS: model name reported by the OpenAI API.
ROCMFP4_ALIAS=qwen35b-a3b-mtp

# ROCMFP4_PORT: host port (container is 8080). 8081 avoids clashing with the base stack.
ROCMFP4_PORT=8081

# ROCMFP4_CTX: context window. Model max is 262144; keep it modest for first load.
ROCMFP4_CTX=32768

# ROCMFP4_THEROCK_VERSION: TheRock ROCm dist pinned into the image (gfx1151 is
# in ROCm's support matrix from 7.13). This is the LAST 7.13 nightly; TheRock
# has no plain "7.13.0" artifact, so a dated pin is as stable as it gets.
ROCMFP4_THEROCK_VERSION=7.13.0a20260515

# ROCMFP4_GFX: GPU ISA to compile for. gfx1151 = Strix Halo.
ROCMFP4_GFX=gfx1151
